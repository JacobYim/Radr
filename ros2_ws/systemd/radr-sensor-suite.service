[Unit]
Description=Radr ROS2 Sensor Suite (auto start on boot)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=radr
Group=radr
SupplementaryGroups=dialout video plugdev
WorkingDirectory=/home/radr/Radr
Environment=PYTHONUNBUFFERED=1
ExecStart=/bin/bash -lc 'source /home/radr/Radr/venv/bin/activate && source /opt/ros/humble/setup.bash && exec ros2 launch /home/radr/Radr/ros2_ws/src/radr_sensor_hub/launch/sensor_suite.launch.py'
Restart=always
RestartSec=5
KillSignal=SIGINT
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
